# ── Build agent binary ────────────────────────────────────
FROM docker.io/library/golang:1.26-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /bin/agent ./cmd/agent

# ── Final ─────────────────────────────────────────────────
# Alpine rather than scratch: the agent executes commands via sh -c,
# so a shell and basic coreutils must be present in the image.
FROM docker.io/library/alpine:3.21

RUN adduser -D -H -u 65534 nonroot
COPY --from=build /bin/agent /agent

USER nonroot
ENTRYPOINT ["/agent"]
